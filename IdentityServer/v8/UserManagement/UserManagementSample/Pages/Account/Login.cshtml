@page
@model UserManagementSample.Pages.Account.LoginModel

<div class="row">
    <div class="col-md-6 offset-md-3">
        <h2>Sign In</h2>
        <hr />
        <a asp-page="/Account/LoginWithOtp" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-primary">
            Sign in with OTP
        </a>
        <a asp-page="/Account/LoginWithPassword" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-secondary mt-2">
            Sign in with Password
        </a>
        <a href="/Account/ExternalLogin?provider=Google&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? string.Empty)" class="btn btn-danger mt-2">
            Sign in with Google
        </a>
    </div>
</div>
