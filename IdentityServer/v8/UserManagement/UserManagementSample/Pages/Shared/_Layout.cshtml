<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - User Management Sample</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <a class="navbar-brand" asp-page="/Index">User Management Sample</a>
                <ul class="nav-links">
                    <li><a asp-page="/Index">Home</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-dropdown">
                            <span class="nav-user nav-dropdown-toggle">@User.Identity.Name &#9660;</span>
                            <ul class="nav-dropdown-menu">
                                <li><a asp-page="/Manage/ManageProfile">Manage Profile</a></li>
                                <li><a asp-page="/Manage/ChangePassword">Change Password</a></li>
                                <li><a asp-page="/Manage/Setup2FA">Setup 2FA</a></li>
                                <li><a asp-page="/Manage/ManagePasskeys">Manage Passkeys</a></li>
                            </ul>
                        </li>
                        <li><a asp-page="/Admin/Users">Users</a></li>
                        <li><a asp-page="/Admin/Import">Import</a></li>
                        <li>
                            <form method="post" action="/Account/Logout" style="display:inline">
                                <button type="submit" class="btn-link">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li><a asp-page="/Account/Login">Login</a></li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <div class="main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="footer-container">
            &copy; @DateTime.UtcNow.Year - User Management Sample
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
