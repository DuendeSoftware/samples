@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="form-container">
            <h2 class="mb-4 brand-title text-center">Enter New Password</h2>

            @if (Model.ErrorMessages.Count > 0)
            {
                <div class="alert alert-danger mb-4" role="alert">
                    @foreach (var error in Model.ErrorMessages)
                    {
                        <div><i class="bi bi-exclamation-triangle-fill me-2"></i>@error</div>
                    }
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors alert alert-danger" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <input asp-for="Password" type="password" class="form-control form-control-lg"
                           placeholder="Enter your password" required autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="PasswordConfirmation" class="form-label fw-semibold">Password Confirmation</label>
                    <input asp-for="PasswordConfirmation" type="password" class="form-control form-control-lg"
                           placeholder="Confirm your password" required autocomplete="new-password" />
                    <span asp-validation-for="PasswordConfirmation" class="text-danger"></span>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle me-2"></i>Set Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
