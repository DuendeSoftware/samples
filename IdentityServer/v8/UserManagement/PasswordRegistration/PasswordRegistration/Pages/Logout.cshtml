@page
@model LogoutModel
@{
  ViewData["Title"] = "Log out";
}

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="form-container text-center">
      <h2 class="mb-4 brand-title">Log out</h2>
      <p class="text-muted mb-4">Are you sure you want to log out?</p>

      <form method="post">
        <input type="hidden" asp-for="ReturnUrl"/>
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-box-arrow-right me-2"></i>Yes, log out
          </button>
          <a href="@(Model.ReturnUrl ?? Url.Page("/Index"))" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle me-2"></i>Cancel
          </a>
        </div>
      </form>
    </div>
  </div>
</div>
