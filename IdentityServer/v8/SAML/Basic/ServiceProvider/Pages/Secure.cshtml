@page
@model SecureModel
@{
    ViewData["Title"] = "Secure";
}

<h1>Claims</h1>
<p>You are authenticated via SAML 2.0 as <strong>@User.Identity?.Name</strong>.</p>

<table class="table">
    <thead>
        <tr>
            <th>Claim Type</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var claim in User.Claims)
        {
            <tr>
                <td>@claim.Type</td>
                <td>@claim.Value</td>
            </tr>
        }
    </tbody>
</table>

<form asp-page="/Logout" method="post">
    <button type="submit" class="btn btn-danger">Logout</button>
</form>
